{
  "name": "diavgeia-cli",
  "version": "0.1.0",
  "description": "TypeScript client and CLI for the Diavgeia (Greek Government Transparency) API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "diavgeia": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "docs"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "SMOKE=1 vitest run smoke.integration",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "diavgeia",
    "greece",
    "government",
    "transparency",
    "open-data",
    "api-client",
    "cli"
  ],
  "author": "Schema Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/schemalabz/diavgeia-cli.git"
  },
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
